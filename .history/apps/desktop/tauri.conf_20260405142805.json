{
  "productName": "crø",
  "version": "0.1.0",
  "identifier": "dev.cro.chat",
  "build": {
    "beforeDevCommand": "cd ../../apps/chat-web && npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "cd ../../apps/chat-web && npm run build",
    "frontendDist": "../../apps/chat-web/dist"
  },
  "app": {
    "title": "crø – Team Chat",
    "windows": [
      {
        "title": "crø",
        "width": 1200,
        "height": 800,
        "minWidth": 400,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://localhost ws://localhost:3001; img-src 'self' data: blob:; style-src 'self' 'unsafe-inline'; script-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": ""
    }
  }
}
